{
  "schemaVersion": 1,
  "id": "popupevents",
  "version": "${version}",
  "name": "Hypixel Popupevents",
  "description": "Client-side Hypixel party, trade, friend, guild, and duel request HUD popups.",
  "authors": [
    "MagicClutch"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "assets/popupevents/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "de.hypixel.popupevents.client.PopupeventsClient"
    ],
    "main": [
      "de.hypixel.popupevents.Popupevents"
    ]
  },
  "mixins": [
    "popupevents.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "resourcefulconfig": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
